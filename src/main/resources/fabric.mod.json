{
	"schemaVersion": 1,
	"id": "panorama_screenmake",
	"version": "${version}",
	"name": "Panorama ScreenMake",
	"description": "Use unused code in the vanilla client to make screenshots panorama!",
	"authors": [
		"Egor201"
	],
	"contact": {
		"sources": "https://github.com/Egor201-alt/PanoramaScreenMake",
		"issues": "https://github.com/Egor201-alt/PanoramaScreenMake/issues"
	},
	"license": "LGPL-3.0-or-later",
	"icon": "assets/panorama_screenmake/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"me.egor201.panorama_screenmake.PanoramaCraft"
		],
		"modmenu": [
	        "me.egor201.panorama_screenmake.ModMenuIntegration"
	    ]
	},
  	"mixins": [
    	"panoramascreenmake.mixins.json"
  	],
  	"depends": {
      	"fabricloader": ">=0.17.2",
      	"fabric": "*",
      	"minecraft": ">=1.21.6 <1.22.0",
